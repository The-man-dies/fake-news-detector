@startuml
autonumber
skinparam theme plain
skinparam participantBackgroundColor #FEFEFE
skinparam participantBorderColor #333333
skinparam sequenceArrowColor #555555
skinparam sequenceLifeLineBorderColor #555555

' ==========================================
' ACTORS AND PARTICIPANTS
' ==========================================
actor "Citizen (Watcher)" as Watcher
participant "API Service" as API
database "PostgreSQL (Prisma)" as DB
actor "Journalist" as Journalist
actor "Director" as Director

' ==========================================
' PHASE 1: REPORT SUBMISSION BY CITIZEN
' ==========================================
== Phase 1: Report Submission ==
Watcher -> API : POST /reports
activate API

API -> API : authenticateToken()
note right of API : JWT Verification\nrole = CITIZEN

API -> DB : INSERT INTO reports (citizen_id, theme, title, content, status)
activate DB
DB --> API : Report created (id generated)
deactivate DB

API --> Watcher : 201 Created (report_id)
deactivate API

' ==========================================
' PHASE 2: ASSIGNMENT BY JOURNALIST
' ==========================================
== Phase 2: Assignment by Journalist ==
Journalist -> API : POST /investigations
activate API

API -> API : authenticateToken()
note right of API : JWT Verification\nrole = JOURNALIST

API -> DB : SELECT * FROM reports WHERE status = 'OPEN' AND id = ?
activate DB
DB --> API : Report available
deactivate DB

API -> DB : INSERT INTO investigations (report_id, journalist_id, status, attempt_count)
activate DB
DB --> API : Investigation created
deactivate DB

API -> DB : UPDATE reports SET status = 'IN_PROGRESS' WHERE id = ?
activate DB
DB --> API : Report updated
deactivate DB

API --> Journalist : 201 Created (investigation_id)
deactivate API

' ==========================================
' PHASE 3: EVIDENCE SUBMISSION BY WATCHER
' ==========================================
== Phase 3: Evidence Submission by Watcher ==
Watcher -> API : POST /evidence
activate API

API -> API : authenticateToken()
note right of API : JWT Verification\nrole = CITIZEN\ncitizenType = WATCHER

API -> DB : SELECT * FROM actors WHERE id = ? AND citizen_type = 'WATCHER'
activate DB
DB --> API : Watcher confirmed
deactivate DB

API -> DB : INSERT INTO evidence (content, title, investigation_id, watcher_id)
activate DB
DB --> API : Evidence created
deactivate DB

API --> Watcher : 201 Created (evidence_id)
deactivate API

' ==========================================
' PHASE 4: EVIDENCE REVIEW BY JOURNALIST
' ==========================================
== Phase 4: Evidence Review by Journalist ==
Journalist -> API : GET /investigations/{id}/evidence
activate API

API -> API : authenticateToken()
API -> DB : SELECT * FROM evidence WHERE investigation_id = ?
activate DB
DB --> API : Evidence list
deactivate DB

API --> Journalist : 200 OK (evidences)
deactivate API

' ==========================================
' PHASE 5: INVESTIGATION SUBMISSION FOR REVIEW
' ==========================================
== Phase 5: Investigation Submission for Review ==
Journalist -> API : PATCH /investigations/{id}
activate API

API -> API : authenticateToken()
API -> DB : UPDATE investigations SET media_category = ?, draft_verdict = ?, investigation_notes = ?, status = 'PENDING_REVIEW'
activate DB
DB --> API : Investigation updated
deactivate DB

API --> Journalist : 200 OK
deactivate API

' ==========================================
' PHASE 6: VALIDATION BY DIRECTOR
' ==========================================
== Phase 6: Validation by Director ==
Director -> API : POST /investigations/{id}/approve
activate API

API -> API : authenticateToken()
note right of API : JWT Verification\nrole = EDITORIAL_DIRECTOR

API -> DB : UPDATE investigations SET status = 'PUBLISHED'
activate DB
DB --> API : Investigation approved
deactivate DB

API -> DB : INSERT INTO publications (investigation_id, approved_by_id, final_verdict, published_at)
activate DB
DB --> API : Publication created
deactivate DB

API -> DB : INSERT INTO notifications (actor_id, type, theme, message, publication_id)
activate DB
note right of DB : Batch notifications for\naffected actors
DB --> API : Notifications created
deactivate DB

API --> Director : 201 Created (publication_id)
deactivate API

' ==========================================
' PHASE 7: ACTOR NOTIFICATIONS
' ==========================================
== Phase 7: Actor Notifications ==
Watcher -> API : GET /notifications
activate API

API -> API : authenticateToken()
API -> DB : SELECT * FROM notifications WHERE actor_id = ? AND is_active = true
activate DB
DB --> API : Unread notifications
deactivate DB

API --> Watcher : 200 OK (notifications)
deactivate API

' ==========================================
' PHASE 8: WATCHER APPLICATION
' ==========================================
== Phase 8: Watcher Application ==
Watcher -> API : POST /watcher-applications
activate API

API -> API : authenticateToken()
API -> DB : SELECT * FROM actors WHERE id = ? AND citizen_type = 'REGULAR'
activate DB
DB --> API : Regular citizen confirmed
deactivate DB

API -> DB : INSERT INTO watcher_applications (applicant_id, status)
activate DB
DB --> API : Application created
deactivate DB

API --> Watcher : 201 Created
deactivate API

' ==========================================
' PHASE 9: WATCHER APPROVAL BY DIRECTOR
' ==========================================
== Phase 9: Watcher Approval by Director ==
Director -> API : PATCH /watcher-applications/{id}/approve
activate API

API -> API : authenticateToken()
API -> DB : UPDATE watcher_applications SET status = 'APPROVED'
activate DB
DB --> API : Application approved
deactivate DB

API -> DB : UPDATE actors SET citizen_type = 'WATCHER' WHERE id = ?
activate DB
DB --> API : Citizen promoted to Watcher
deactivate DB

API --> Director : 200 OK
deactivate API

@enduml
