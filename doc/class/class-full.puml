@startuml
skinparam handwritten false
skinparam shadowless true
skinparam defaultFontName "Arial"
skinparam RoundCorner 10

' --- Educational Colors ---
!define DOMAIN_BG #EEF4F9
!define APP_BG #FFF5E6
!define SERVICE_BG #F0F9F0
!define INFRA_BG #F8F9FA
!define BORDER_COLOR #B0C4DE

note "Corrected DDD Architecture based on actual implementation\n- Actor unifies Citizen, Journalist and Director via role field\n- Investigation replaces Analysis with complete lifecycle\n- Evidence is submitted by Watchers (promoted citizens)\n- Publication contains final verifications" as N1

' ==========================================
' DOMAIN LAYER
' ==========================================
package "Domain Layer (Business Logic)" <<Rectangle>> {

    class "Actor" as Actor << (A,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - name: String
        - email: String
        - role: Role (CITIZEN/JOURNALIST/EDITORIAL_DIRECTOR)
        - status: AccountStatus (ACTIVE/DISABLED/BANNED)
        - citizenType: CitizenType (REGULAR/WATCHER)
        - engagementScore: Int
        - lastInboxRead: DateTime
        - statusReason: StatusReason?
        - statusReasonDetails: String?
        --
        **Common Behaviors**
        - isActive(): Boolean
        - canLogin(): Boolean
        - incrementEngagementScore(points)
        - markInboxAsRead()
    }

    class "Citizen" as Citizen << (E,DOMAIN_BG) >> {
        **Specific Attributes**
        - openReportsCount: Int
        - maxOpenReports: Int = 3
        --
        **Behaviors**
        - canSubmitReport(): Boolean
        - canSubmitEvidence(): Boolean
        - canApplyForWatcher(): Boolean
        - isWatcher(): Boolean
        - submitReport(theme, title, content): Report
        - submitEvidence(investigationId, title, content): Evidence
        - applyForWatcher(): void
        - promoteToWatcher(): void
        - reportResolved(): void
        - ban(reason, details): void
        - disable(reason, details): void
        - activate(): void
        - getProfile(): Object
    }

    class "Journalist" as Journalist << (E,DOMAIN_BG) >> {
        **Specific Attributes**
        - activeInvestigationsCount: Int
        - maxActiveInvestigations: Int = 1
        --
        **Behaviors**
        - canAnalyze(): Boolean
        - canPickReport(): Boolean
        - pickReport(report): Investigation
        - submitInvestigationDraft(investigation, category, verdict, notes): void
        - submitForReview(investigation): void
        - correctInvestigation(investigation, notes): void
        - onInvestigationPublished(investigation): void
        - ban(reason, details): void
        - disable(reason, details): void
        - activate(): void
        - getHistory(): Object
    }

    class "Director" as Director << (E,DOMAIN_BG) >> {
        **Specific Attributes**
        - status: DirectorStatus (ACTIVE/DISABLED)
        --
        **Behaviors**
        - validateInvestigation(investigation): void
        - rejectInvestigation(investigation, newStatus): void
        - publishInvestigation(investigation): void
        - markAsUnverifiable(investigation): void
        - approveWatcherApplication(application): void
        - rejectWatcherApplication(application): void
        - banCitizen(citizen, reason, details): void
        - disableCitizen(citizen, reason, details): void
        - activateCitizen(citizen): void
        - banJournalist(journalist, reason, details): void
        - disableJournalist(journalist, reason, details): void
        - activateJournalist(journalist): void
        - createInboxSubject(theme, description): InboxSubject
        - archiveInboxSubject(subject): void
    }

    class "Report" as Report << (E,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - citizenId: String
        - theme: String
        - title: String?
        - content: String?
        - status: ReportStatus
        --
        **Behaviors**
        - isOpen(): Boolean
        - canBePicked(): Boolean
        - changeStatus(newStatus): void
        - updateContent(title, content, theme): void
    }

    class "Investigation" as Investigation << (E,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - reportId: String
        - journalistId: String
        - mediaCategory: MediaCategory?
        - draftVerdict: Verdict
        - investigationNotes: String
        - attemptCount: Int
        - status: InvestigationStatus
        --
        **Behaviors**
        - isDraft(): Boolean
        - isPendingReview(): Boolean
        - isPublished(): Boolean
        - canBeEdited(): Boolean
        - updateDraft(category, verdict, notes): void
        - submitForReview(): void
        - requestRevision(newStatus): void
        - approve(): void
        - markAsUnverifiable(): void
    }

    class "Evidence" as Evidence << (E,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - content: String
        - title: String
        - investigationId: String
        - watcherId: String
        --
        **Behaviors**
        - (submitted by Watchers via application service)
    }

    class "AuthoritySource" as AuthoritySource << (V,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - name: String
        - type: SourceType
    }

    class "Publication" as Publication << (A,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - investigationId: String
        - approvedById: String
        - finalVerdict: Verdict
        - publishedAt: DateTime
        - isCorrection: Boolean
        --
        **Behaviors**
        - (generates notifications automatically)
    }

    class "Notification" as Notification << (E,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - type: NotificationType
        - theme: String
        - message: String
        - isActive: Boolean
        - actorId: String
        - publicationId: String?
    }

    class "InboxSubject" as InboxSubject << (V,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - theme: String
        - description: String
        - createdById: String
        - status: InboxSubjectStatus
        - origin: InboxSubjectOrigin
        --
        **Behaviors**
        - archive(): void
    }

    class "WatcherApplication" as WatcherApp << (E,DOMAIN_BG) >> {
        **Attributes**
        - id: String
        - applicantId: String
        - status: WatcherApplicationStatus
        --
        **Behaviors**
        - approve(): void
        - reject(): void
    }

    ' Domain Relations
    Actor <|-- Citizen
    Actor <|-- Journalist  
    Actor <|-- Director

    Citizen "1" -- "0..*" Report : submits >
    Report "1" -- "0..1" Investigation : becomes >
    Journalist "1" -- "0..*" Investigation : conducts >
    Investigation "1" -- "0..*" Evidence : contains >
    Evidence "0..*" -- "1" Citizen : submitted by (Watcher) >
    
    Investigation "1" -- "0..1" Publication : produces >
    Publication "1" -- "0..*" Notification : generates >
    Notification "0..*" -- "1" Actor : recipient >
    Publication "1" -- "0..*" AuthoritySource : verified by >
    
    Director "1" -- "0..*" InboxSubject : creates/archives >
    Citizen "1" -- "0..1" WatcherApp : applies for >
    Director "1" -- "0..*" WatcherApp : approves/rejects >
}

' ==========================================
' APPLICATION LAYER (ORCHESTRATION)
' ==========================================
package "Application Layer (Orchestration)" <<Rectangle>> {

    class "FactCheckingService" as AppService << (S,APP_BG) >> {
        --
        **Commands (Modifies State)**
        - submitReport(citizenId, theme, title, content, media)
        - pickReport(journalistId, reportId)
        - submitInvestigationDraft(journalistId, investigationId, data)
        - submitForReview(journalistId, investigationId)
        - approveInvestigation(directorId, investigationId)
        - rejectInvestigation(directorId, investigationId, newStatus)
        - submitEvidence(watcherId, investigationId, evidence)
        - applyForWatcher(citizenId)
        - processWatcherApplication(directorId, applicationId, decision)
        - manageUserStatus(directorId, targetUserId, action, reason)
        - manageInboxSubject(directorId, action, subjectData)
    }

    class "QueryService" as QueryService << (S,APP_BG) >> {
        --
        **Queries (Read Operations)**
        - getActorProfile(actorId)
        - getActorHistory(actorId)
        - getAvailableReports()
        - getJournalistInvestigations(journalistId)
        - getPendingInvestigations()
        - getPublications(filters)
        - getNotifications(actorId)
        - getInboxSubjects()
        - getWatcherApplications()
        - getDashboard(directorId)
    }

    class "SecurityService" as SecurityService << (S,SERVICE_BG) >> {
        --
        **Cross-cutting Methods**
        - authenticate(token): Actor
        - authorize(actor, action): Boolean
        - validatePermissions(role, resource): Boolean
    }

    AppService .right.> SecurityService : uses >
    QueryService .right.> SecurityService : uses >
}

' ==========================================
' INFRASTRUCTURE LAYER
' ==========================================
package "Infrastructure Layer (Persistence)" <<Rectangle>> {

    class "ActorRepository" as ActorRepo << (R,INFRA_BG) >> {
        - save(actor): Actor
        - findById(id): Actor?
        - findByEmail(email): Actor?
        - findByRole(role): Actor[]
        - updateStatus(id, status, reason): void
    }

    class "ReportRepository" as ReportRepo << (R,INFRA_BG) >> {
        - save(report): Report
        - findById(id): Report?
        - findByCitizenId(citizenId): Report[]
        - findAvailable(): Report[]
        - updateStatus(id, status): void
    }

    class "InvestigationRepository" as InvestRepo << (R,INFRA_BG) >> {
        - save(investigation): Investigation
        - findById(id): Investigation?
        - findByJournalistId(journalistId): Investigation[]
        - findByReportId(reportId): Investigation?
        - findPendingReview(): Investigation[]
        - updateStatus(id, status): void
    }

    class "PublicationRepository" as PubRepo << (R,INFRA_BG) >> {
        - save(publication): Publication
        - findById(id): Publication?
        - findByFilters(filters): Publication[]
        - findByInvestigationId(investigationId): Publication?
    }

    class "NotificationRepository" as NotifRepo << (R,INFRA_BG) >> {
        - save(notification): Notification
        - findByActorId(actorId): Notification[]
        - markAsRead(id): void
        - createForPublication(publication): Notification[]
    }
}

' --- Dependency Links ---
AppService -up-> Actor : uses >
AppService -up-> Citizen : uses >
AppService -up-> Journalist : uses >
AppService -up-> Director : uses >
AppService -up-> Report : uses >
AppService -up-> Investigation : uses >
AppService -up-> Evidence : uses >
AppService -up-> Publication : uses >
AppService -up-> Notification : uses >
AppService -up-> InboxSubject : uses >
AppService -up-> WatcherApplication : uses >

QueryService -up-> Actor : uses >
QueryService -up-> Citizen : uses >
QueryService -up-> Journalist : uses >
QueryService -up-> Director : uses >

AppService -down-> ActorRepo : uses >
AppService -down-> ReportRepo : uses >
AppService -down-> InvestRepo : uses >
AppService -down-> PubRepo : uses >
AppService -down-> NotifRepo : uses >

QueryService -down-> ActorRepo : uses >
QueryService -down-> ReportRepo : uses >
QueryService -down-> InvestRepo : uses >
QueryService -down-> PubRepo : uses >
QueryService -down-> NotifRepo : uses >

@enduml
