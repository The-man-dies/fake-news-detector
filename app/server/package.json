{
  "name": "server",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir=dist",
    "generate": "bunx prisma generate --config src/infrastructure/config/prisma.config.ts",
    "prisma:validate": "bunx prisma validate --config src/infrastructure/config/prisma.config.ts",
    "migrate": "bunx prisma migrate dev --config src/infrastructure/config/prisma.config.ts",
    "deploy": "bunx prisma migrate deploy --config src/infrastructure/config/prisma.config.ts",
    "reset": "bunx prisma migrate reset --config src/infrastructure/config/prisma.config.ts --force",
    "reset-and-create": "bunx prisma db push --force-reset --config src/infrastructure/config/prisma.config.ts",
    "push": "bunx prisma db push --config src/infrastructure/config/prisma.config.ts",
    "lint": "bunx eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@prisma/engines": "^7.7.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "@types/bun": "latest",
    "prisma": "^7.6.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.83.0"
  }
}