{
  "name": "server",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir=dist",
    "generate": "bunx prisma generate --config src/infrastructure/config/prisma.config.ts",
    "prisma:validate": "bunx prisma validate --config src/infrastructure/config/prisma.config.ts",
    "lint": "bunx eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.2.2",
    "@prisma/engines": "^7.7.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@prisma/client": "^7.6.0",
    "@types/bun": "latest",
    "prisma": "^7.6.0",
    "wrangler": "^4.83.0"
  }
}