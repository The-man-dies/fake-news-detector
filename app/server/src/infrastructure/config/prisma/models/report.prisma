//
// REPORT
//

model Report {
  id     String       @id @default(uuid())
  status ReportStatus @default(OPEN)

  theme   String
  title   String?
  content String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  citizenId String
  citizen   Actor  @relation("CitizenReports", fields: [citizenId], references: [id])

  inboxSubject InboxSubject?

  media ReportMedia[]

  @@map("reports")
}

//
// REPORT MEDIA
//

model ReportMedia {
  id    Int       @id @default(autoincrement())
  url   String
  type  MediaType
  order Int

  reportId String
  report   Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   Actor  @relation(fields: [uploadedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt @default(now())

  @@index([reportId])
}
