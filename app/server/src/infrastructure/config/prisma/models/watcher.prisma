//
// WATCHER APPLICATION
//

model WatcherApplication {
  id         String                   @id @default(uuid())
  motivation String                   @db.Text
  status     WatcherApplicationStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actorId String @unique
  actor   Actor  @relation("WatcherApplicationAuthor", fields: [actorId], references: [id])

  @@map("watcher_applications")
}
